local multiplierSpeed  = 5
local multiplierDrinks = { "Bloxy Cola", "Witches Brew", "Hot Sauce" }

Tabs.Advanced:AddInput("MultiplierSpeed", {
    Title    = "Seconds",
    Default  = "5",
    Callback = function(v)
        multiplierSpeed = math.max(1, tonumber(v) or 5)
    end
})

Tabs.Advanced:AddToggle("AutoMultiplier", {
    Title    = "Auto Put Multiplier (Smart)",
    Default  = false,
    Callback = function(v)
        States.autoMultiplier = v
        if v then
            task.spawn(function()
                while States.autoMultiplier do
                    for _, drink in ipairs(multiplierDrinks) do
                        if not States.autoMultiplier then break end

                        pcall(function()
                            RS:WaitForChild("events"):WaitForChild("buyGear"):FireServer(drink, 1)
                        end)
                        task.wait(0.3)

                        pcall(function()
                            RS:WaitForChild("events"):WaitForChild("equipGear"):FireServer(drink, true)
                        end)
                        task.wait(0.2)

                        for floor = 0, 50 do
                            if not States.autoMultiplier then break end
                            pcall(function()
                                RS:WaitForChild("events"):WaitForChild("useGear"):FireServer({
                                    floor = tostring(floor),
                                    mode  = "floor"
                                })
                            end)
                            task.wait(0.2)
                        end
                    end
                    task.wait(multiplierSpeed)
                end
            end)
        end
    end
})

