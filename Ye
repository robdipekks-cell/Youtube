local function getNames(folder)
    local names = {}
    local f = RS:FindFirstChild(folder)
    if f then
        for _, v in ipairs(f:GetChildren()) do
            names[#names + 1] = v.Name
        end
    end
    return names
end

local function getGearNames()
    local names = {}
    local f = RS:FindFirstChild("gear")
    if f then
        for _, v in ipairs(f:GetChildren()) do
            local low = v.Name:lower()
            if not low:find("award") and not low:find("trophy") then
                names[#names + 1] = v.Name
            end
        end
    end
    return names
end

-- Used by Advanced tab (Auto Multiplier) — reads from Sim folder
local function getMyBuildIDs()
    local ids = {}
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return ids end
    for _, plot in ipairs(plots:GetChildren()) do
        if plot:GetAttribute("plrName") == LocalPlayer.Name then
            local sim = plot:FindFirstChild("Sim")
            if sim then
                for _, build in ipairs(sim:GetChildren()) do
                    ids[#ids + 1] = build.Name
                end
            end
            break
        end
    end
    return ids
end

-- Used by Auto Collect All — reads from both Builds and Sim, merged and deduplicated
local function getMyCollectIDs()
    local ids = {}
    local seen = {}
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return ids end
    for _, plot in ipairs(plots:GetChildren()) do
        if plot:GetAttribute("plrName") == LocalPlayer.Name then
            for _, folderName in ipairs({"Builds", "Sim"}) do
                local folder = plot:FindFirstChild(folderName)
                if folder then
                    for _, build in ipairs(folder:GetChildren()) do
                        if not seen[build.Name] then
                            seen[build.Name] = true
                            ids[#ids + 1] = build.Name
                        end
                    end
                end
            end
            break
        end
    end
    return ids
end

